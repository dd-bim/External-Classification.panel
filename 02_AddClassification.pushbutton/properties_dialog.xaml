<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure Properties"
        Width="1020" Height="760"
        MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Configure Properties"
                       FontSize="18" FontWeight="Bold" Foreground="#1F2937"/>
            <TextBlock Text="Select required attributes and define values for classification export."
                       Margin="0,4,0,0" Foreground="#4B5563" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#D7DCE2" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Apply mode:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,0"/>
                    <RadioButton x:Name="ApplyToAllRadio"
                                 Content="Same properties for all selected elements"
                                 IsChecked="True"
                                 Margin="0,0,20,0"
                                 Checked="ApplyMode_Changed"/>
                    <RadioButton x:Name="ApplyPerElementRadio"
                                 Content="Configure each element individually"
                                 Checked="ApplyMode_Changed"/>
                </StackPanel>

                <StackPanel x:Name="ElementSelectorPanel" Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0" Visibility="Collapsed">
                    <TextBlock Text="Current element:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <Button x:Name="PrevElementBtn" Content="&lt;" Width="28" Height="26" Click="PrevElement_Click"/>
                    <ComboBox x:Name="ElementSelectorCombo" Width="520" Height="26" Margin="8,0,8,0" SelectionChanged="ElementSelector_Changed"/>
                    <Button x:Name="NextElementBtn" Content=">" Width="28" Height="26" Click="NextElement_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D7DCE2" BorderThickness="1" CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="10">
                <StackPanel x:Name="PropertySetsPanel"/>
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="3" x:Name="StatusText"
                   Foreground="#4B5563" FontStyle="Italic"
                   TextWrapping="Wrap" Margin="2,10,2,0"/>

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" x:Name="SaveBtn" Content="Save" Height="32" Click="Save_Click"
                    Background="#2E7D32" Foreground="White" BorderThickness="0"/>
            <Button Grid.Column="3" x:Name="CancelBtn" Content="Cancel" Height="32" Click="Cancel_Click"
                    Background="#6B7280" Foreground="White" BorderThickness="0"/>
        </Grid>
    </Grid>
</Window>
