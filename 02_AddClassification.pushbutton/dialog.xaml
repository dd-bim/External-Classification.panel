<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="External Classification"
        Width="820" Height="720"
        MinWidth="620" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- API URL -->
        <Border Grid.Row="0" Background="#E8F0FE" CornerRadius="4" Padding="8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="API: " FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="UrlDisplay" Text="(not set)" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" MaxWidth="680" Foreground="#333"/>
            </StackPanel>
        </Border>

        <!-- TabControl -->
        <TabControl Grid.Row="1" x:Name="MainTabControl"
                    SelectionChanged="Tab_SelectionChanged"
                    Margin="0,0,0,8">

            <!-- Tab 1: Classify -->
            <TabItem Header="Classify">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="Dictionary:" FontWeight="SemiBold" Padding="0,0,0,2"/>
                    <ComboBox Grid.Row="1" x:Name="DictionaryComboBox"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              StaysOpenOnEdit="True"
                              Margin="0,0,0,10" Height="28"
                              DropDownOpened="DictionaryComboBox_DropDownOpened"
                              DropDownClosed="DictionaryComboBox_DropDownClosed"
                              SelectionChanged="DictionaryComboBox_SelectionChanged"/>

                    <Label Grid.Row="2" Content="Search Class:" FontWeight="SemiBold" Padding="0,0,0,2"/>
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" x:Name="SearchBox"
                                 Height="28" Margin="0,0,0,6"
                                 VerticalContentAlignment="Center"
                                 TextChanged="SearchBox_TextChanged"
                                 IsEnabled="False">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="HintBrush" TileMode="None" Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Class name or code ..." Foreground="#AAAAAA" Margin="4,0,0,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter Property="Background" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <ListBox Grid.Row="1" x:Name="ClassListBox"
                                 SelectionMode="Single"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="ClassListBox_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2">
                                        <TextBlock FontSize="12" TextWrapping="Wrap">
                                            <Run Text="{Binding name}" FontWeight="SemiBold"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding code, StringFormat=({0})}" FontStyle="Italic" Foreground="#444"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding descriptionPart}" FontSize="11" Foreground="#666"
                                                   TextWrapping="Wrap" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="2" Background="#FFFDE7" CornerRadius="4"
                                Padding="8" Margin="0,6,0,0">
                            <StackPanel x:Name="ClassDetailPanel" Visibility="Collapsed">
                                <TextBlock x:Name="DetailCode" FontWeight="Bold"/>
                                <TextBlock x:Name="DetailName" FontSize="13" TextWrapping="Wrap"/>
                                <TextBlock x:Name="DetailUri" FontSize="10" Foreground="#666" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Buttons Tab 1 -->
                    <Grid Grid.Row="4" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="AssignToSelectionBtn"
                            Content="Assign To Current Selection"
                                Height="30" IsEnabled="False"
                                Click="AssignToSelection_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1565C0"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#BDBDBD"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1976D2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Grid.Column="2" x:Name="SelectAndAssignBtn"
                            Content="Select Elements &amp; Assign"
                                Height="30" IsEnabled="False"
                                Click="SelectAndAssign_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#2E7D32"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#BDBDBD"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#388E3C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 2: Overview -->
            <TabItem Header="Overview">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="RefreshOverviewBtn"
                                Content="Refresh Overview"
                                HorizontalAlignment="Left"
                                Padding="12,4" Height="28" Margin="0,0,8,0"
                                Click="RefreshOverview_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#546E7A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#607D8B"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="SelectOverviewInModelBtn"
                                Content="Select In Model"
                                HorizontalAlignment="Left"
                                Padding="12,4" Height="28" Margin="0,0,8,0"
                                Click="SelectOverviewInModel_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#455A64"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#546E7A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="RemoveOverviewSelectedBtn"
                                Content="Remove Classification"
                                HorizontalAlignment="Left"
                                Padding="12,4" Height="28"
                                Click="RemoveOverviewSelected_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#C62828"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D32F2F"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <ListView Grid.Row="1" x:Name="OverviewList"
                              SelectionMode="Extended"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding is_classified_str}" Value="True">
                                        <Setter Property="Background" Value="#E8F5E9"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="" Width="30">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding status}"
                                                       FontWeight="Bold" FontSize="14"
                                                       HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Category" DisplayMemberBinding="{Binding category}" Width="130"/>
                                <GridViewColumn Header="Name / Type" DisplayMemberBinding="{Binding elem_name}" Width="210"/>
                                <GridViewColumn Header="Classifications" Width="420">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding classifications}"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="410"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <TextBlock Grid.Row="2" x:Name="OverviewStats"
                               Margin="0,6,0,0" FontStyle="Italic" Foreground="#555"/>
                </Grid>
            </TabItem>

            <!-- Tab 3: Properties Management -->
            <TabItem Header="Properties">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="RefreshPropertiesBtn"
                                Content="Refresh Properties"
                                HorizontalAlignment="Left"
                                Padding="12,4" Height="28" Margin="0,0,8,0"
                                Click="RefreshProperties_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#546E7A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#607D8B"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock x:Name="PropertiesStatusText" Text="No properties configured."
                                   VerticalAlignment="Center" Foreground="#666" FontStyle="Italic"/>
                    </StackPanel>

                    <TreeView Grid.Row="1" x:Name="PropertiesTree"
                             Padding="8"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             MouseDoubleClick="PropertiesTree_MouseDoubleClick">
                        <!-- Properties will be populated here -->
                    </TreeView>

                    <Border Grid.Row="2" Background="#FFF3E0" CornerRadius="4" Padding="8" Margin="0,8,0,0">
                        <TextBlock Text="Double-click a property row to edit its value. Changes are saved immediately."
                                   Foreground="#555" FontSize="11" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status line -->
        <Border Grid.Row="2" Margin="0,0,0,6">
            <TextBlock x:Name="StatusText" Text="Please select a dictionary."
                       Foreground="#555" FontStyle="Italic" TextWrapping="Wrap"/>
        </Border>

        <!-- Close -->
        <Button Grid.Row="3" Content="Close"
                HorizontalAlignment="Right"
                Height="30" Width="90"
                Click="Close_Click"/>
    </Grid>
</Window>
